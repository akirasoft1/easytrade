# OTel configuration template — managed by Bluebox
#
# IMPORTANT: Before editing this file, load the bluebox-otel-instrumentation skill
# in your coding agent. The skill completes all language-specific SDK wiring.
#
# Token security: your ingest token belongs in your secret manager or CI secrets,
# NEVER in this file, NEVER committed to version control.
# When you need to set the Authorization header in your SDK or collector, use:
#   Authorization=Api-Token <your-ingest-token>
# (replace <your-ingest-token> with the actual token from your Bluebox workspace).

# Fixed: use http/protobuf — do NOT switch to gRPC/port 4317.
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# OTLP ingest endpoint (resolved via `bluebox otlp-endpoint`).
# The SDK/agent appends the signal path (e.g. /v1/traces) to this base URL.
OTEL_EXPORTER_OTLP_ENDPOINT=https://qgv89709.apps.dynatrace.com/api/v2/otlp

# Service identity.
# This easyTrade deployment is instrumented on Kubernetes via the OpenTelemetry
# Operator (zero-code injection), NOT by exporting these env vars from a shell.
# Per-service identity is therefore set at the workload level:
#   - OTEL_SERVICE_NAME is derived automatically by the Operator from each
#     Deployment's pod (app label / container name), so it is intentionally left
#     blank here. Override per-Deployment only if you need a name other than the
#     workload name.
#   - Shared resource attributes are applied centrally in the Instrumentation CR
#     at kubernetes-manifests/release/opentelemetry-instrumentation.yaml.
OTEL_SERVICE_NAME=

# Additional resource attributes (applied via the Instrumentation CR `spec.resource`
# and the shared OTEL_RESOURCE_ATTRIBUTES env it injects).
OTEL_RESOURCE_ATTRIBUTES=service.namespace=easytrade,deployment.environment=demo
